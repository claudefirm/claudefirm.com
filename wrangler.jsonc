{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "claudefirm",
  "main": "worker.js",
  "compatibility_date": "2025-09-27",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  // Vite builds the SPA into ./dist; the Worker serves it via the ASSETS
  // binding. Unknown paths fall back to index.html (client-side SPA).
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    // Route these to the Worker FIRST. Without this, the SPA fallback
    // (not_found_handling) intercepts browser navigation requests
    // (Sec-Fetch-Dest: document) for non-asset paths and serves index.html
    // before the Worker runs — which silently shadowed /admin + the API.
    "run_worker_first": ["/admin", "/admin/*", "/api/*", "/callback"]
  },
  "kv_namespaces": [
    {
      "binding": "WAITLIST",
      "id": "7a77531c04a440d59b409192363fab11"
    }
  ],
  // Non-secret OIDC config (Authentik @ auth.darrengruber.com). The Authentik
  // application slug is "claudefirm-admin" (provisioned in darren-iac).
  "vars": {
    "OIDC_ISSUER": "https://auth.darrengruber.com/application/o/claudefirm-admin/",
    "OIDC_REDIRECT_URI": "https://claudefirm.com/callback"
  }
  // Secrets — set with `wrangler secret put <NAME>`:
  //   - TURNSTILE_SECRET_KEY : Turnstile server-side secret (waitlist anti-bot)
  //   - OIDC_CLIENT_ID       : Authentik OAuth2 client id   (tofu output / SSM)
  //   - OIDC_CLIENT_SECRET   : Authentik OAuth2 client secret (tofu output / SSM)
  //   - OIDC_AUTH_SECRET     : >=32-char key signing the session JWT cookie
}
