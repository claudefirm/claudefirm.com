{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "claudefirm",
  "main": "worker.js",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "kv_namespaces": [
    {
      "binding": "WAITLIST",
      "id": "7a77531c04a440d59b409192363fab11"
    }
  ]
  // Secrets (set via `wrangler secret put <NAME> --name claudefirm`):
  //   - TURNSTILE_SECRET_KEY: Cloudflare Turnstile server-side secret
  //
  // Not configurable via wrangler (managed via infra/setup.sh):
  //   - Cloudflare Access application for /admin + /api/admin
  //   - Cloudflare Turnstile widget (invisible mode)
}
